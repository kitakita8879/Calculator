<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="com.example.calculator.Operator" />

        <variable
            name="viewModel"
            type="com.example.calculator.CalculatorViewModel" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/calculator_background"
        android:orientation="vertical"
        android:padding="16dp"
        tools:context=".MainActivity">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="16dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/calculator_surface"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/calculator_outline"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="bottom"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/expression"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:contentDescription="@string/expression_label"
                    android:gravity="end"
                    android:text="@{viewModel.expressionText}"
                    android:textColor="@color/calculator_outline"
                    android:textSize="18sp"
                    tools:text="12 + 7 x 3 =" />

                <TextView
                    android:id="@+id/result"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:contentDescription="@string/result_label"
                    android:gravity="end"
                    android:text="@{viewModel.displayText}"
                    android:textColor="@color/calculator_on_surface"
                    android:textSize="40sp"
                    android:textStyle="bold"
                    tools:text="33" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="4"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="8dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/clear"
                    style="@style/Widget.Calculator.Button.Function"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/button_clear"
                    android:onClick="@{() -> viewModel.onClearClick()}"
                    android:text="@string/clear" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/left_arr"
                    style="@style/Widget.Calculator.Button.Function"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/button_precision_down"
                    android:enabled="@{viewModel.canDecreasePrecision}"
                    android:onClick="@{() -> viewModel.onPrecisionDownClick()}"
                    android:text="@string/left_arrow" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/right_arr"
                    style="@style/Widget.Calculator.Button.Function"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/button_precision_up"
                    android:enabled="@{viewModel.canIncreasePrecision}"
                    android:onClick="@{() -> viewModel.onPrecisionUpClick()}"
                    android:text="@string/right_arrow" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/div"
                    style="@style/Widget.Calculator.Button.Operator"
                    android:layout_weight="1"
                    android:contentDescription="@string/button_divide"
                    android:onClick="@{() -> viewModel.onOperatorClick(Operator.DIVIDE)}"
                    android:text="@string/div" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="8dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_7"
                    style="@style/Widget.Calculator.Button"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:onClick="@{() -> viewModel.onDigitClick(7)}"
                    android:text="@string/_7" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_8"
                    style="@style/Widget.Calculator.Button"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:onClick="@{() -> viewModel.onDigitClick(8)}"
                    android:text="@string/_8" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_9"
                    style="@style/Widget.Calculator.Button"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:onClick="@{() -> viewModel.onDigitClick(9)}"
                    android:text="@string/_9" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/mul"
                    style="@style/Widget.Calculator.Button.Operator"
                    android:layout_weight="1"
                    android:contentDescription="@string/button_multiply"
                    android:onClick="@{() -> viewModel.onOperatorClick(Operator.MULTIPLY)}"
                    android:text="@string/mul" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="8dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_4"
                    style="@style/Widget.Calculator.Button"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:onClick="@{() -> viewModel.onDigitClick(4)}"
                    android:text="@string/_4" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_5"
                    style="@style/Widget.Calculator.Button"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:onClick="@{() -> viewModel.onDigitClick(5)}"
                    android:text="@string/_5" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_6"
                    style="@style/Widget.Calculator.Button"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:onClick="@{() -> viewModel.onDigitClick(6)}"
                    android:text="@string/_6" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/sub"
                    style="@style/Widget.Calculator.Button.Operator"
                    android:layout_weight="1"
                    android:contentDescription="@string/button_subtract"
                    android:onClick="@{() -> viewModel.onOperatorClick(Operator.SUBTRACT)}"
                    android:text="@string/sub" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="8dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_1"
                    style="@style/Widget.Calculator.Button"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:onClick="@{() -> viewModel.onDigitClick(1)}"
                    android:text="@string/_1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_2"
                    style="@style/Widget.Calculator.Button"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:onClick="@{() -> viewModel.onDigitClick(2)}"
                    android:text="@string/_2" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_3"
                    style="@style/Widget.Calculator.Button"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:onClick="@{() -> viewModel.onDigitClick(3)}"
                    android:text="@string/_3" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/add"
                    style="@style/Widget.Calculator.Button.Operator"
                    android:layout_weight="1"
                    android:contentDescription="@string/button_add"
                    android:onClick="@{() -> viewModel.onOperatorClick(Operator.ADD)}"
                    android:text="@string/add" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/del"
                    style="@style/Widget.Calculator.Button.Function"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/button_delete"
                    android:onClick="@{() -> viewModel.onDeleteClick()}"
                    android:text="@string/delete" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_0"
                    style="@style/Widget.Calculator.Button"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:onClick="@{() -> viewModel.onDigitClick(0)}"
                    android:text="@string/_0" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/dot"
                    style="@style/Widget.Calculator.Button"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:contentDescription="@string/button_decimal"
                    android:enabled="@{viewModel.canInputDecimal}"
                    android:onClick="@{() -> viewModel.onDecimalClick()}"
                    android:text="@string/dot" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/equ"
                    style="@style/Widget.Calculator.Button.Equals"
                    android:layout_weight="1"
                    android:contentDescription="@string/button_equals"
                    android:onClick="@{() -> viewModel.onEqualsClick()}"
                    android:text="@string/equ" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</layout>

<resources>
    <style name="Widget.Calculator.Button" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:minHeight">64dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/calculator_on_surface</item>
        <item name="android:textSize">24sp</item>
        <item name="backgroundTint">@color/calculator_surface</item>
        <item name="cornerRadius">24dp</item>
        <item name="strokeColor">@color/calculator_outline</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.Calculator.Button.Function" parent="Widget.Calculator.Button">
        <item name="backgroundTint">@color/calculator_function</item>
    </style>

    <style name="Widget.Calculator.Button.Operator" parent="Widget.Calculator.Button">
        <item name="backgroundTint">@color/calculator_operator</item>
    </style>

    <style name="Widget.Calculator.Button.Equals" parent="Widget.Material3.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:minHeight">64dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/calculator_on_primary</item>
        <item name="android:textSize">24sp</item>
        <item name="backgroundTint">@color/calculator_primary</item>
        <item name="cornerRadius">24dp</item>
    </style>
</resources>
